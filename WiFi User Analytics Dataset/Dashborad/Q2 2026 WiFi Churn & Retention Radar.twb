      <column caption='Inactive Users' datatype='integer' name='[Active Users (copy)_0214974870396935]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Active_Status] = &quot;Inactive&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Active Status' datatype='string' name='[Active_Status]' role='dimension' type='nominal' />
      <column caption='Auth Method' datatype='string' name='[Auth_Method]' role='dimension' type='nominal' />
      <column caption='Active Users' datatype='integer' name='[Calculation_0214974862954496]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Active_Status] = &quot;Active&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Churn % ' datatype='real' name='[Calculation_0214974863798273]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Active_Status] = &quot;Inactive&quot; THEN 1 ELSE 0 END) / COUNTD([User_ID])' />
      </column>
      <column caption='Negative Feedback %' datatype='real' name='[Calculation_0214974864281602]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Previous_Feedback] = &quot;Poor&quot; OR [Previous_Feedback] = &quot;Leave to other provider&quot; THEN 1 ELSE 0 END) / COUNTD([User_ID])' />
      </column>
      <column caption='Total User' datatype='integer' name='[Calculation_0214974871609352]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([User_ID])' />
      </column>
      <column caption='Revenue Lost' datatype='real' name='[Calculation_0214974876250121]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Active_Status] = &quot;Inactive&quot; THEN [Subscription_Price] ELSE 0 END' />
